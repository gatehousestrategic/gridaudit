# From Supabase: Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# From Anthropic console: console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here

# Server
PORT=3000
